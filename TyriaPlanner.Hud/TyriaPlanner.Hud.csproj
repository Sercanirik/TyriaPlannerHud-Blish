<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <RootNamespace>TyriaPlanner.Hud</RootNamespace>
    <AssemblyName>TyriaPlanner.Hud</AssemblyName>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- Official Blish HUD NuGet package · pulls in MonoGame.Framework
         transitively. ExcludeAssets="runtime;contentFiles;analyzers" keeps
         the host runtime DLLs out of our build output and silences the
         analyzer warning the BlishHUD package would otherwise add. -->
    <PackageReference Include="BlishHUD" Version="1.3.0" ExcludeAssets="runtime;contentFiles;analyzers" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.1" />
    <!-- MEF lives in System.ComponentModel.Composition · keep the NuGet
         version (not the framework reference) so the SSRD build env on
         the Blish HUD side doesn't need the .NET Framework targeting pack
         installed. -->
    <PackageReference Include="System.ComponentModel.Composition" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- HttpClient lives in System.Net.Http on the .NET Framework target.
         Required for our ApiClient. -->
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <ItemGroup>
    <None Include="manifest.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Some hosted build pipelines (notably SSRD) invoke `dotnet build`
       without first running `dotnet restore`, so project.assets.json is
       missing and NETSDK1004 fires. Fall back to an explicit restore as
       a pre-build step when the assets file is absent. Local builds and
       GitHub Actions already restore, so this target is a no-op there. -->
  <Target Name="EnsureNuGetRestore"
          BeforeTargets="CollectPackageReferences;_GenerateRestoreGraphProjectEntry;Build"
          Condition="!Exists('$(BaseIntermediateOutputPath)project.assets.json')">
    <Exec Command="dotnet restore &quot;$(MSBuildProjectFullPath)&quot;" />
  </Target>

  <!-- BlishHUD's NuGet build targets auto-package the module into a .bhm
       (renamed zip) at bin/Release/<AssemblyName>.bhm after each Release
       build, so no custom packaging step is needed. -->

  <!-- Mirror the freshly built .bhm into ../releases so the user has a
       stable, shallow path to grab the latest build from. Skips silently
       when ../releases doesn't exist (e.g. when SSRD builds the module
       from a sparse checkout that does not include the parent folder). -->
  <Target Name="CopyToReleases" AfterTargets="BuildBlishHUDModule"
          Condition="'$(Configuration)' == 'Release' AND Exists('$(MSBuildProjectDirectory)\..\releases')">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).bhm"
          DestinationFolder="$(MSBuildProjectDirectory)\..\releases\"
          ContinueOnError="true"
          SkipUnchangedFiles="false" />
  </Target>

</Project>
