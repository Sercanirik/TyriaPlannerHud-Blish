bin/
obj/*
**/obj/*
# SSRD's build pipeline does `dotnet build --no-restore` and bails with
# NETSDK1004 when project.assets.json is missing (see Freesnöw's note in
# the registration flow). Committing the freshly restored assets file
# satisfies that check; the file is regenerated by extract-public.ps1
# on every Release build before each tag.
!**/obj/project.assets.json
.vs/
*.user
*.suo
